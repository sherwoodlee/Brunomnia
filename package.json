{
  "name": "brunomnia",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "bin": {
    "brunomnia": "bin/brunomnia.cjs"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build && npm run build:cli",
    "build:cli": "esbuild cli/brunomnia.ts --bundle --platform=node --format=cjs --banner:js=\"#!/usr/bin/env node\" --outfile=bin/brunomnia.cjs",
    "cli": "npm run build:cli && node bin/brunomnia.cjs",
    "test:cli-template-smoke": "npm run build:cli && node scripts/cli-template-smoke.mjs",
    "test:cli-runner-smoke": "npm run build:cli && node scripts/cli-runner-preview-smoke.mjs",
    "test:cli-container": "npm run build:cli && node scripts/cli-container-smoke.mjs",
    "preview": "vite preview",
    "test": "vitest run",
    "tauri": "tauri"
  },
  "dependencies": {
    "@faker-js/faker": "9.7.0",
    "@tauri-apps/api": "^2.0.0",
    "@xmldom/xmldom": "0.8.13",
    "date-fns": "3.6.0",
    "fuzzysort": "1.9.0",
    "graphql": "16.10.0",
    "graphql-language-service": "5.5.0",
    "js-md5": "0.8.3",
    "json-bigint": "1.0.0",
    "jsonpath-plus": "10.4.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "undici": "8.7.0",
    "xpath": "0.0.34",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.0.0",
    "@types/json-bigint": "1.0.4",
    "@types/node": "^24.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^5.0.0",
    "esbuild": "^0.28.1",
    "typescript": "~5.9.0",
    "vite": "^7.0.0",
    "vitest": "^3.2.0"
  }
}
