{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Brunomnia",
  "version": "0.1.0",
  "identifier": "dev.brunomnia.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "security": {
      "csp": "default-src 'self'; connect-src ipc: http://ipc.localhost; img-src 'self' asset: http://asset.localhost data:; style-src 'self' 'unsafe-inline'; font-src 'self' data:"
    },
    "windows": [
      {
        "title": "Brunomnia",
        "width": 1536,
        "height": 980,
        "minWidth": 960,
        "minHeight": 640,
        "resizable": true,
        "fullscreen": false
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "DeveloperTool",
    "shortDescription": "Local-first API workbench",
    "longDescription": "A free, local-first workbench for building, sending, and testing API requests."
  }
}
