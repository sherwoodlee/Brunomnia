{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Brunomnia",
  "version": "0.1.0",
  "identifier": "dev.brunomnia.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "security": {
      "csp": "default-src 'self'; connect-src ipc: http://ipc.localhost; worker-src blob:; img-src 'self' asset: http://asset.localhost data:; style-src 'self' 'unsafe-inline'; font-src 'self' data:"
    },
    "windows": [
      {
        "title": "Brunomnia",
        "width": 1536,
        "height": 980,
        "minWidth": 960,
        "minHeight": 640,
        "resizable": true,
        "fullscreen": false
      }
    ]
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "icon": [
      "icons/icon.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "DeveloperTool",
    "macOS": {
      "minimumSystemVersion": "10.15"
    },
    "shortDescription": "Local-first API workbench",
    "longDescription": "A free, local-first workbench for building, sending, and testing API requests."
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEJEMDBCNTI3MzNDNjYzRTYKUldUbVk4WXpKN1VBdlk5RjRJTWlrTkpYOE81VnlFMDNnSk5GdUhsR1pPQ1BIcFBQTytaZWVGYUEK"
    }
  }
}
