{
  "format": "brunomnia",
  "version": 33,
  "name": "CLI template smoke",
  "activeRequestId": "cli-template-main",
  "activeEnvironmentId": "cli-template-local",
  "collections": [
    {
      "id": "cli-template-dependencies",
      "name": "CLI Template Dependencies",
      "expanded": true,
      "environment": [],
      "requests": [
        {
          "id": "cli-template-seed",
          "name": "Seed dependent response and cookie",
          "protocol": "http",
          "method": "GET",
          "url": "{{ baseUrl }}/seed",
          "headers": [],
          "bodyMode": "none",
          "body": "",
          "preRequestScript": "",
          "tests": ""
        }
      ]
    },
    {
      "id": "cli-template-smoke",
      "name": "CLI Template Smoke",
      "expanded": true,
      "environment": [],
      "requests": [
        {
          "id": "cli-template-main",
          "name": "Verify portable template parity",
          "protocol": "http",
          "method": "POST",
          "url": "{{ baseUrl }}/verify",
          "headers": [
            { "id": "cli-template-content-type", "name": "Content-Type", "value": "application/json", "enabled": true },
            { "id": "cli-template-os", "name": "X-Template-OS", "value": "{% os 'platform' %}", "enabled": true },
            { "id": "cli-template-hash", "name": "X-Template-Hash", "value": "{% hash 'sha256', 'hex', 'hello' %}", "enabled": true },
            { "id": "cli-template-date", "name": "X-Template-Date", "value": "{% now 'custom', 'yyyy-MM-dd' %}", "enabled": true },
            { "id": "cli-template-chain", "name": "X-Template-Chain", "value": "{% response 'body', 'cli-template-seed', '$.token', 'always', '60' %}|{% cookie 'session' %}", "enabled": true }
          ],
          "bodyMode": "json",
          "body": "{\"file\": {% file 'examples/cli-template-file.json' %}}",
          "preRequestScript": "",
          "tests": "const payload = insomnia.response.json();\ninsomnia.test('File, OS, hash, and custom time render through the CLI', () => {\n  insomnia.expect(payload.file).to.equal('template-file-ok');\n  insomnia.expect(payload.os).to.be.a('string').and.not.be.empty;\n  insomnia.expect(payload.hash).to.equal('2cf24dba5fb0a30e26e83b2ac5b9e29e1b161e5c1fa7425e73043362938b9824');\n  insomnia.expect(payload.date).to.have.lengthOf(10);\n  insomnia.expect(payload.date.split('-')).to.have.lengthOf(3);\n});\ninsomnia.test('Dependent response and cookie state stay continuous', () => {\n  insomnia.expect(payload.chain).to.equal('dependency-token|cli-cookie');\n  insomnia.expect(payload.cookie).to.contain('session=cli-cookie');\n});"
        }
      ]
    }
  ],
  "environments": [
    {
      "id": "cli-template-local",
      "name": "CLI template localhost",
      "variables": [
        { "id": "cli-template-base-url", "name": "baseUrl", "value": "http://127.0.0.1:43199", "enabled": true }
      ],
      "parentId": "",
      "private": false,
      "color": "#66c68d"
    }
  ],
  "preferences": {
    "maxHistoryResponses": 0,
    "requestTimeoutMs": 5000,
    "validateCertificates": true
  }
}
